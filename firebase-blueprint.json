{
  "entities": {
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A support ticket submitted by a user",
      "type": "object",
      "properties": {
        "subject": { "type": "string", "description": "Subject of the ticket" },
        "message": { "type": "string", "description": "Details of the ticket" },
        "status": { "type": "string", "enum": ["open", "closed", "in-progress"] },
        "userId": { "type": "string", "description": "UID of the user who submitted the ticket" },
        "userEmail": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["subject", "message", "status", "userId", "createdAt", "updatedAt"]
    },
    "Location": {
      "title": "Location",
      "description": "A business location (e.g. café, hotel)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "address": { "type": "string" },
        "userId": { "type": "string" },
        "portalConfig": {
          "type": "object",
          "properties": {
            "themeColor": { "type": "string" },
            "logoUrl": { "type": "string", "nullable": true },
            "welcomeMessage": { "type": "string", "nullable": true },
            "termsOfService": { "type": "string", "nullable": true },
            "layoutTheme": { "type": "string", "nullable": true },
            "sessionDuration": { "type": "number", "nullable": true },
            "allowExtension": { "type": "boolean", "nullable": true },
            "redirectUrl": { "type": "string", "nullable": true }
          }
        },
        "notificationConfig": {
          "type": "object",
          "properties": {
            "dauThreshold": { "type": "number", "nullable": true },
            "emailEnabled": { "type": "boolean", "nullable": true },
            "pushEnabled": { "type": "boolean", "nullable": true },
            "notifyEmail": { "type": "string", "nullable": true }
          }
        },
        "wifiConfig": {
          "type": "object",
          "properties": {
            "timeLimit": { "type": "string", "nullable": true },
            "customTimeLimit": { "type": "number", "nullable": true },
            "bandwidth": { "type": "string", "nullable": true },
            "autoRenew": { "type": "boolean", "nullable": true },
            "autoRenewLimit": { "type": "number", "nullable": true },
            "macBypassEnabled": { "type": "boolean", "nullable": true },
            "macBypassGracePeriod": { "type": "number", "nullable": true }
          }
        },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "type", "address", "userId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "User support tickets"
    },
    "locations/{locationId}": {
      "schema": "Location",
      "description": "User business locations"
    }
  }
}
