{
  "entities": {
    "Connection": {
      "title": "Connection",
      "description": "A user connection to the wifi",
      "type": "object",
      "properties": {
        "locationId": { "type": "string" },
        "locationName": { "type": "string" },
        "userId": { "type": "string", "nullable": true },
        "device": { "type": "string" },
        "os": { "type": "string" },
        "duration": { "type": "number" },
        "connectedAt": { "type": "timestamp" },
        "status": { "type": "string", "enum": ["Connecté", "Déconnecté"] }
      },
      "required": ["locationId", "locationName", "device", "os", "duration", "connectedAt", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A payment transaction",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "customerEmail": { "type": "string", "nullable": true },
        "locationId": { "type": "string", "nullable": true },
        "userId": { "type": "string", "nullable": true },
        "createdAt": { "type": "string" }
      },
      "required": ["sessionId", "amount", "currency", "status", "createdAt"]
    },
    "Voucher": {
      "title": "Voucher",
      "description": "A generated wifi voucher code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "duration": { "type": "string" },
        "locationId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "used", "revoked"] },
        "createdAt": { "type": "string" },
        "usedAt": { "type": "string", "nullable": true },
        "createdBy": { "type": "string" }
      },
      "required": ["code", "duration", "locationId", "status", "createdAt", "createdBy"]
    },
    "Discount": {
      "title": "Discount",
      "description": "A generated wifi discount code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "flat"] },
        "value": { "type": "number" },
        "locationId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired"] },
        "createdAt": { "type": "string" },
        "uses": { "type": "number" },
        "maxUses": { "type": "number", "nullable": true },
        "createdBy": { "type": "string" }
      },
      "required": ["code", "type", "value", "locationId", "status", "createdAt", "uses", "createdBy"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A support ticket submitted by a user",
      "type": "object",
      "properties": {
        "subject": { "type": "string", "description": "Subject of the ticket" },
        "message": { "type": "string", "description": "Details of the ticket" },
        "status": { "type": "string", "enum": ["open", "closed", "in-progress"] },
        "userId": { "type": "string", "description": "UID of the user who submitted the ticket" },
        "userEmail": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["subject", "message", "status", "userId", "createdAt", "updatedAt"]
    },
    "Location": {
      "title": "Location",
      "description": "A business location (e.g. café, hotel)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "address": { "type": "string" },
        "userId": { "type": "string" },
        "portalConfig": {
          "type": "object",
          "properties": {
            "themeColor": { "type": "string" },
            "logoUrl": { "type": "string", "nullable": true },
            "welcomeMessage": { "type": "string", "nullable": true },
            "termsOfService": { "type": "string", "nullable": true },
            "layoutTheme": { "type": "string", "nullable": true },
            "sessionDuration": { "type": "number", "nullable": true },
            "allowExtension": { "type": "boolean", "nullable": true },
            "redirectUrl": { "type": "string", "nullable": true }
          }
        },
        "notificationConfig": {
          "type": "object",
          "properties": {
            "dauThreshold": { "type": "number", "nullable": true },
            "emailEnabled": { "type": "boolean", "nullable": true },
            "pushEnabled": { "type": "boolean", "nullable": true },
            "notifyEmail": { "type": "string", "nullable": true }
          }
        },
        "wifiConfig": {
          "type": "object",
          "properties": {
            "timeLimit": { "type": "string", "nullable": true },
            "customTimeLimit": { "type": "number", "nullable": true },
            "bandwidth": { "type": "string", "nullable": true },
            "autoRenew": { "type": "boolean", "nullable": true },
            "autoRenewLimit": { "type": "number", "nullable": true },
            "macBypassEnabled": { "type": "boolean", "nullable": true },
            "macBypassGracePeriod": { "type": "number", "nullable": true }
          }
        },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "type", "address", "userId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "User support tickets"
    },
    "locations/{locationId}": {
      "schema": "Location",
      "description": "User business locations"
    },
    "connections/{connectionId}": {
      "schema": "Connection",
      "description": "Wifi connections"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Stripe transactions for wifi"
    },
    "vouchers/{voucherId}": {
      "schema": "Voucher",
      "description": "Wifi vouchers generated by owners"
    },
    "discounts/{discountId}": {
      "schema": "Discount",
      "description": "Discount codes for Wi-Fi sessions"
    }
  }
}
